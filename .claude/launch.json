{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Dev Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start"],
      "port": 8081
    },
    {
      "name": "Expo iOS",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--ios"],
      "port": 8081
    },
    {
      "name": "Expo Android",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--android"],
      "port": 8081
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web"],
      "port": 19006
    },
    {
      "name": "Coach Mockup",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4040", "--directory", "/tmp/mockup_preview"],
      "port": 4040
    }
  ]
}
