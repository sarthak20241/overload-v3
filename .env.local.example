EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyYOUR_ANON_KEY_HERE

# AI Coach (set in Supabase Edge Function secrets)
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# CLERK_ISSUER=https://YOUR-CLERK-FRONTEND-API.clerk.accounts.dev
#   ↑ Clerk Dashboard -> API Keys -> "Frontend API URL"
#   The edge functions verify JWTs via this issuer's JWKS endpoint. Pinning
#   the issuer prevents valid-but-foreign Clerk tokens from authenticating.
# CLERK_SECRET_KEY=sk_test_...   (only delete-account needs this — for the
#   server-side Clerk DELETE /v1/users/{id} call)

# ─── Required Clerk dashboard config (no env var, but mandatory) ─────────────
# Clerk -> JWT Templates -> "supabase"
#   Signing key:  paste Supabase Project Settings -> API -> JWT Secret
#   Claims:       { "sub": "{{user.id}}" }
#   Lifetime:     60s (default)
# Without this template, every supabase request from a signed-in user falls
# back to the anon key and RLS policies will block all per-user reads/writes.
