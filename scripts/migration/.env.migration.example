# Copy to .env.migration (gitignored) and fill in. NEVER commit the real file.
#
# Source: legacy MongoDB Atlas cluster (real host kept out of git).
# Password must be URL-encoded (e.g. @ -> %40).
MONGO_URI="mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority"

# Comma-separated identifiers for the users being migrated (matched by email/username).
# Put the real emails only in your local .env.migration, never in this example.
MIGRATE_USERS="user1@example.com,user2@example.com"
