# legacy-peer-deps makes npm resolve optional peer dependencies the way
# older npm versions did — by NOT auto-hoisting them. This keeps the
# package-lock.json deterministic across npm 10 (EAS Build) and npm 11+
# (local dev with newer Node). Without this, optional peers like
# utf-8-validate can be pinned at different major versions locally vs in
# CI, breaking `npm ci`.
legacy-peer-deps=true
